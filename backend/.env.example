# ─── Required ────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
MONGO_USERNAME=your_mongodb_atlas_username
MONGO_PASSWORD=your_mongodb_atlas_password
MONGO_DB=shadii                          # optional, defaults to 'shadii'

# ─── JWT Token Lifetimes ─────────────────────────────────────────────────────
JWT_EXPIRES_IN=15m                        # Access token lifetime (15 min recommended)
REFRESH_TOKEN_DAYS=30                     # Refresh token lifetime (days)

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=no-reply@shadii.pk
SMTP_PASS=your_smtp_password_or_app_password

# ─── Payment Gateways ─────────────────────────────────────────────────────────
EASYPAISA_MERCHANT_ID=your_easypaisa_store_id
JAZZCASH_MERCHANT_ID=your_jazzcash_merchant_id
GOOGLE_PLAY_PACKAGE_NAME=pk.shadii.app
# Option 1 (recommended): Base64-encode the entire Google service account JSON:
#   base64 -i play-service-account.json | tr -d '\n'
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=
# Option 2: Provide the raw JSON as a single env var
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# Option 3: Provide individual fields
GOOGLE_PLAY_SERVICE_ACCOUNT_PROJECT_ID=
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PLAY_PRODUCT_BASIC=pk.shadii.app.basic_1m
GOOGLE_PLAY_PRODUCT_STANDARD=pk.shadii.app.standard_3m
GOOGLE_PLAY_PRODUCT_PREMIUM=pk.shadii.app.premium_6m
GOOGLE_PLAY_PRODUCT_BOOST=pk.shadii.app.boost_3d
GOOGLE_PLAY_PRODUCT_CONTACT_UNLOCK=pk.shadii.app.contact_unlock

# ─── Stripe (Card Payments) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
# Option 1 (recommended): Base64-encode your entire service-account.json file:
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_json

# Option 2: Individual fields from service-account.json
# FIREBASE_PROJECT_ID=shadii-pk
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@shadii-pk.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Cloudinary (Image Storage — optional) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
