{
  "expo": {
    "name": "Shadii.pk",
    "slug": "shadii-pk",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pk.shadii"
    },
    "android": {
      "package": "pk.shadii",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_MEDIA_IMAGES",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Shadii.pk needs camera access for profile photo and verification."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Shadii.pk needs photo access to set your profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5C0F31",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Shadii.pk"
        }
      ],
      "expo-iap"
    ]
  }
}
